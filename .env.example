# MarcenAI - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# OpenAI API Key
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Database (Não precisa alterar em desenvolvimento)
DATABASE_URL=postgresql://marcenai:marcenai123@postgres:5432/marcenai_db

# MinIO (Não precisa alterar em desenvolvimento)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=project-images
MINIO_SECURE=false

# App Config
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
